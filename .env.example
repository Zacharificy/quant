ALPACA_PAPER_API_KEY=your_paper_api_key
ALPACA_PAPER_SECRET_KEY=your_paper_secret_key
ALPACA_PAPER=true
ALPACA_DATA_FEED=iex
BOT_STATE_PATH=alpaca_stock_bot_state.json
BOT_WATCHLIST_PATH=watchlist.json
BOT_BLOCK_DATES=
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change_this_before_deploying
BOT_ENABLE_AUTO_LOOP=true
BOT_SCAN_INTERVAL_MINUTES=20
# Easiest Discord setup: create a webhook in your trades/positions channel.
DISCORD_TRADE_WEBHOOK_URL=
# Alternative setup if you want bot-token posting instead of a webhook:
DISCORD_TOKEN=
# TOKEN= is also supported if your old Discord bot used that variable name.
# TOKEN=
DISCORD_TRADE_CHANNEL_ID=
DISCORD_SHOW_ONLINE=true
# Railway volume example, if you mount a volume at /data:
# BOT_STATE_PATH=/data/alpaca_stock_bot_state.json
# BOT_WATCHLIST_PATH=/data/watchlist.json
# BOT_LEVELS_PATH=/data/trade_levels.json
